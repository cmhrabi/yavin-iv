{
  "name": "@cmhrabi/yavin-protocol",
  "version": "0.0.1",
  "description": "Shared protocol types and Zod schemas between yavin-iv and rogue-one.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmhrabi/yavin-iv.git",
    "directory": "packages/protocol"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
